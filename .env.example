# CRM v2 Backend — Environment Variables
# Copy this to .env.development (or .env) and fill in values
# Do NOT commit .env files to git

# Server
PORT=8080
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database (same PostgreSQL as crm_backend)
DATABASE_HOST=
DATABASE_USER=
DATABASE_PASS=
DATABASE=
DB_SCHEMA=mad_crm_dev
DB_SSL=false
DB_LOGGING=false
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

# Auth
JWT_SECRET=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
