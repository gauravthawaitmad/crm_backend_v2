{
  "name": "crm_v2_backend",
  "version": "1.0.0",
  "description": "CRM v2 Backend — Express + Service + Repository layers",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "sync:users:dev": "NODE_ENV=development node scripts/runUserSync.js",
    "sync:users:staging": "NODE_ENV=staging node scripts/runUserSync.js",
    "sync:users:prod": "NODE_ENV=production node scripts/runUserSync.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.4",
    "node-cache": "^5.1.2",
    "pg": "^8.13.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.2"
  }
}
